<script>
const S = {
  get: k => { try { return JSON.parse(localStorage.getItem(k)) || []; } catch { return []; } },
  set: (k, v) => { try { localStorage.setItem(k, JSON.stringify(v)); } catch {} }
};
const KS = 'glos_sessions', KI = 'glos_interviews', KJ = 'glos_jobs';
let sessions = S.get(KS), interviews = S.get(KI), jobs = S.get(KJ);

const pages = {
  dashboard: { title: 'Dashboard', sub: 'Visão geral do progresso' },
  english:   { title: 'Inglês', sub: 'Prática de inglês falado' },
  interviews:{ title: 'Entrevistas', sub: 'Registro e diagnóstico' },
  pipeline:  { title: 'Pipeline', sub: 'Vagas aplicadas' }
};

function switchPanel(name) {
  document.querySelectorAll('.nav-item').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.panel').forEach(el => el.classList.remove('active'));
  document.getElementById('panel-' + name).classList.add('active');
  event.currentTarget.classList.add('active');
  document.getElementById('page-title').textContent = pages[name].title;
  document.getElementById('page-sub').textContent = pages[name].sub;
  if (name === 'dashboard') renderDashboard();
}

function today() { return new Date().toISOString().slice(0,10); }
function fmt(d) { return d ? d.slice(5) : ''; }

function calcStreak() {
  if (!sessions.length) return 0;
  const dates = [...new Set(sessions.map(s => s.date))].sort().reverse();
  let streak = 0, d = new Date();
  for (const ds of dates) {
    const diff = Math.round((d - new Date(ds)) / 86400000);
    if (diff <= 1) { streak++; d = new Date(ds); } else break;
  }
  return streak;
}

function saveSession() {
  const s = {
    id: Date.now(),
    date: document.getElementById('e-date').value || today(),
    focus: document.getElementById('e-focus').value,
    transcript: document.getElementById('e-transcript').value,
    confidence: parseInt(document.getElementById('e-conf').value) || null,
    fillers: parseInt(document.getElementById('e-fill').value) || null,
    duration: parseInt(document.getElementById('e-dur').value) || null,
    win: document.getElementById('e-win').value,
    gap: document.getElementById('e-gap').value,
  };
  sessions.unshift(s);
  S.set(KS, sessions);
  renderSessionHistory();
  updateEnglishMetrics();
  updateNavBadges();
  clearFields(['e-transcript','e-win','e-gap','e-conf','e-fill','e-dur']);
}

function clearFields(ids) {
  ids.forEach(id => { const el = document.getElementById(id); if(el) el.value = ''; });
}

function renderSessionHistory() {
  const el = document.getElementById('e-history');
  if (!sessions.length) { el.innerHTML = '<div class="empty"><i class="ti ti-microphone-off"></i>Nenhuma sessão ainda</div>'; return; }
  el.innerHTML = sessions.slice(0,10).map(s => `
    <div class="list-item">
      <div class="list-item-icon" style="background:var(--accent-bg);color:var(--accent);">
        <i class="ti ti-microphone"></i>
      </div>
      <div class="list-item-body">
        <div class="list-item-title">${s.focus}</div>
        <div class="list-item-sub">${s.date}${s.duration ? ' · ' + s.duration + 'min' : ''}${s.win ? ' · ' + s.win : ''}</div>
        ${s.gap ? '<div class="list-item-sub" style="margin-top:2px;">Gap: ' + s.gap + '</div>' : ''}
      </div>
      <div class="list-item-meta">
        ${s.confidence ? '<span class="badge badge-green">' + s.confidence + '/10</span>' : ''}
        ${s.fillers != null ? '<span class="badge badge-amber">' + s.fillers + ' fillers</span>' : ''}
      </div>
    </div>`).join('');
}

function updateEnglishMetrics() {
  document.getElementById('e-m-total').textContent = sessions.length;
  document.getElementById('e-m-streak').textContent = calcStreak() + ' dias';
  const withConf = sessions.filter(s => s.confidence);
  if (withConf.length) {
    const avg = withConf.reduce((a,b) => a + b.confidence, 0) / withConf.length;
    document.getElementById('e-m-conf').textContent = avg.toFixed(1) + '/10';
  }
  const lf = sessions.find(s => s.fillers != null);
  document.getElementById('e-m-fill').textContent = lf ? lf.fillers : '—';
}

function saveInterview() {
  const iv = {
    id: Date.now(),
    date: document.getElementById('i-date').value || today(),
    company: document.getElementById('i-co').value,
    role: document.getElementById('i-role').value,
    outcome: document.getElementById('i-outcome').value,
    scores: {
      star: parseInt(document.getElementById('i-star').value) || null,
      fluency: parseInt(document.getElementById('i-flu').value) || null,
      presence: parseInt(document.getElementById('i-pres').value) || null,
      tech: parseInt(document.getElementById('i-tech').value) || null,
      fit: parseInt(document.getElementById('i-fit').value) || null,
    },
    transcript: document.getElementById('i-transcript').value,
    win: document.getElementById('i-win').value,
    gap: document.getElementById('i-gap').value,
    feedback: document.getElementById('i-fb').value,
  };
  interviews.unshift(iv);
  S.set(KI, interviews);
  renderInterviewHistory();
  renderInterviewPatterns();
  updateInterviewMetrics();
  updateNavBadges();
  clearFields(['i-co','i-role','i-win','i-gap','i-fb','i-transcript','i-star','i-flu','i-pres','i-tech','i-fit']);
}

const outcomeLabel = { pending:'Aguardando', advanced:'Avançou', rejected:'Não avançou', offer:'Oferta' };
const outcomeBadge = { pending:'badge-gray', advanced:'badge-green', rejected:'badge-red', offer:'badge-blue' };

function renderInterviewHistory() {
  const el = document.getElementById('i-history');
  if (!interviews.length) { el.innerHTML = '<div class="empty"><i class="ti ti-users"></i>Nenhuma entrevista ainda</div>'; return; }
  el.innerHTML = interviews.map(iv => `
    <div class="list-item">
      <div class="list-item-icon" style="background:var(--purple-bg);color:var(--purple);">
        <i class="ti ti-briefcase"></i>
      </div>
      <div class="list-item-body">
        <div class="list-item-title">${iv.company || '—'} — ${iv.role || '—'}</div>
        <div class="list-item-sub">${iv.date}${iv.gap ? ' · Gap: ' + iv.gap : ''}</div>
      </div>
      <div class="list-item-meta">
        <span class="badge ${outcomeBadge[iv.outcome]}">${outcomeLabel[iv.outcome]}</span>
        <button class="del-btn" onclick="deleteInterview(${iv.id})"><i class="ti ti-trash"></i></button>
      </div>
    </div>`).join('');
}

function deleteInterview(id) {
  interviews = interviews.filter(i => i.id !== id);
  S.set(KI, interviews);
  renderInterviewHistory();
  renderInterviewPatterns();
  updateInterviewMetrics();
  updateNavBadges();
}

function updateInterviewMetrics() {
  document.getElementById('i-m-total').textContent = interviews.length;
  const adv = interviews.filter(i => i.outcome === 'advanced' || i.outcome === 'offer').length;
  document.getElementById('i-m-adv').textContent = adv;
  document.getElementById('i-m-rate').textContent = interviews.length ? Math.round(adv/interviews.length*100) + '%' : '—';
  const dims = ['star','fluency','presence','tech','fit'];
  const allScores = interviews.flatMap(iv => dims.map(d => iv.scores[d]).filter(Boolean));
  document.getElementById('i-m-score').textContent = allScores.length ? (allScores.reduce((a,b)=>a+b,0)/allScores.length).toFixed(1)+'/5' : '—';
}

function renderInterviewPatterns() {
  const el = document.getElementById('i-patterns');
  if (interviews.length < 2) { el.innerHTML = '<div class="empty"><i class="ti ti-chart-radar"></i>Registre ao menos 2 entrevistas</div>'; return; }
  const dims = ['star','fluency','presence','tech','fit'];
  const labels = { star:'STAR / estrutura', fluency:'Fluência em inglês', presence:'Confiança / presença', tech:'Conhecimento técnico', fit:'Fit cultural' };
  const avgs = {};
  dims.forEach(d => {
    const vals = interviews.map(i => i.scores[d]).filter(Boolean);
    avgs[d] = vals.length ? vals.reduce((a,b)=>a+b,0)/vals.length : null;
  });
  const sorted = dims.filter(d => avgs[d]).sort((a,b) => avgs[a]-avgs[b]);
  const getColor = v => v < 2.5 ? '#DC2626' : v < 3.5 ? '#D97706' : '#16A34A';
  el.innerHTML = sorted.map(d => `
    <div class="prog-row">
      <span class="prog-label">${labels[d]}</span>
      <div class="prog-track"><div class="prog-fill" style="width:${Math.round(avgs[d]/5*100)}%;background:${getColor(avgs[d])}"></div></div>
      <span class="prog-val" style="color:${getColor(avgs[d])}">${avgs[d].toFixed(1)}</span>
    </div>`).join('') +
    (sorted[0] ? `<div class="insight">Maior gap: <strong>${labels[sorted[0]]}</strong> (${avgs[sorted[0]].toFixed(1)}/5) — priorize isso na próxima sessão de prática.</div>` : '');
}

function saveJob() {
  const j = {
    id: Date.now(),
    date: document.getElementById('p-date').value || today(),
    company: document.getElementById('p-co').value,
    role: document.getElementById('p-role').value,
    channel: document.getElementById('p-channel').value,
    status: document.getElementById('p-status').value,
    notes: document.getElementById('p-notes').value,
  };
  jobs.unshift(j);
  S.set(KJ, jobs);
  renderJobList();
  updatePipelineMetrics();
  updateNavBadges();
  clearFields(['p-co','p-role','p-notes']);
}

const statusLabel = { applied:'Aplicado', screening:'Screening', interview:'Entrevista', offer:'Oferta', rejected:'Não avançou' };
const statusBadge = { applied:'badge-gray', screening:'badge-blue', interview:'badge-purple', offer:'badge-green', rejected:'badge-red' };

function renderJobList() {
  const el = document.getElementById('p-list');
  if (!jobs.length) { el.innerHTML = '<div class="empty"><i class="ti ti-send"></i>Nenhuma vaga adicionada</div>'; return; }
  el.innerHTML = jobs.map(j => `
    <div class="list-item">
      <div class="list-item-icon" style="background:var(--green-bg);color:var(--green);">
        <i class="ti ti-building"></i>
      </div>
      <div class="list-item-body">
        <div class="list-item-title">${j.company || '—'} — ${j.role || '—'}</div>
        <div class="list-item-sub">${j.channel} · ${j.date}${j.notes ? ' · ' + j.notes : ''}</div>
      </div>
      <div class="list-item-meta">
        <span class="badge ${statusBadge[j.status]}">${statusLabel[j.status]}</span>
        <button class="del-btn" onclick="deleteJob(${j.id})"><i class="ti ti-trash"></i></button>
      </div>
    </div>`).join('');
}

function deleteJob(id) {
  jobs = jobs.filter(j => j.id !== id);
  S.set(KJ, jobs);
  renderJobList();
  updatePipelineMetrics();
  updateNavBadges();
}

function updatePipelineMetrics() {
  document.getElementById('p-m-total').textContent = jobs.length;
  const active = jobs.filter(j => j.status === 'screening' || j.status === 'interview').length;
  document.getElementById('p-m-active').textContent = active;
  const offers = jobs.filter(j => j.status === 'offer').length;
  document.getElementById('p-m-offers').textContent = offers;
  document.getElementById('p-m-conv').textContent = jobs.length ? Math.round(offers/jobs.length*100)+'%' : '—';
}

function updateNavBadges() {
  document.getElementById('nav-sessions').textContent = sessions.length;
  document.getElementById('nav-interviews').textContent = interviews.length;
  document.getElementById('nav-pipeline').textContent = jobs.length;
}

function renderDashboard() {
  document.getElementById('d-sessions').textContent = sessions.length;
  document.getElementById('d-streak').textContent = 'Streak: ' + calcStreak() + ' dias';
  const adv = interviews.filter(i => i.outcome === 'advanced' || i.outcome === 'offer').length;
  document.getElementById('d-interviews').textContent = interviews.length;
  document.getElementById('d-rate').textContent = 'Taxa de avanço: ' + (interviews.length ? Math.round(adv/interviews.length*100)+'%' : '—');
  document.getElementById('d-pipeline').textContent = jobs.length;
  document.getElementById('d-offers').textContent = 'Ofertas: ' + jobs.filter(j=>j.status==='offer').length;
  const withConf = sessions.filter(s=>s.confidence);
  document.getElementById('d-confidence').textContent = withConf.length ? (withConf.reduce((a,b)=>a+b.confidence,0)/withConf.length).toFixed(1)+'/10' : '—';

  const chartEl = document.getElementById('d-chart-area');
  if (sessions.length < 2) {
    chartEl.innerHTML = '<div class="empty"><i class="ti ti-chart-line"></i>Registre sessões para ver evolução</div>';
  } else {
    const data = sessions.slice(0,10).reverse().filter(s=>s.confidence);
    const maxH = 70;
    chartEl.innerHTML = `<div class="bar-chart">${data.map(s => {
      const h = Math.round(s.confidence/10*maxH);
      const col = s.confidence>=7?'#16A34A':s.confidence>=5?'#D97706':'#DC2626';
      return `<div class="bar-wrap"><div class="bar-val">${s.confidence}</div><div class="bar" style="height:${h}px;background:${col}"></div><div style="font-size:10px;color:var(--text-3);white-space:nowrap;">${fmt(s.date)}</div></div>`;
    }).join('')}</div>`;
  }

  const allGaps = [...sessions.map(s=>s.gap), ...interviews.map(i=>i.gap)].filter(Boolean);
  const gapsEl = document.getElementById('d-gaps');
  if (!allGaps.length) {
    gapsEl.innerHTML = '<div class="empty"><i class="ti ti-alert-circle"></i>Sem dados ainda</div>';
  } else {
    const freq = {};
    ['filler','star','estrutura','confiança','fluência','vocabulário','why this company','presença','ritmo','pronúncia'].forEach(k => {
      allGaps.forEach(g => { if(g.toLowerCase().includes(k)) freq[k]=(freq[k]||0)+1; });
    });
    const sorted = Object.entries(freq).sort((a,b)=>b[1]-a[1]).slice(0,5);
    gapsEl.innerHTML = sorted.length ? sorted.map(([k,v]) =>
      `<div class="prog-row">
        <span class="prog-label">${k}</span>
        <div class="prog-track"><div class="prog-fill" style="width:${Math.round(v/allGaps.length*100)}%;background:#1A56DB;"></div></div>
        <span class="prog-val" style="color:var(--text-2)">${v}x</span>
      </div>`).join('') :
      '<div style="font-size:12px;color:var(--text-3)">Sem padrões claros ainda</div>';
  }

  const actEl = document.getElementById('d-actions');
  const actions = [];
  if (!sessions.length) actions.push({ text: 'Registrar primeira sessão de inglês', sub: 'Google Meet + Otter.ai → cole a transcrição', badge: 'badge-blue', bText: 'Hoje' });
  if (!interviews.length) actions.push({ text: 'Registrar as 6 entrevistas anteriores', sub: 'Mesmo sem transcrição, os scores já geram diagnóstico', badge: 'badge-amber', bText: 'Esta semana' });
  if (!jobs.length) actions.push({ text: 'Adicionar vagas ativas no pipeline', sub: 'Brite + Remote Leverage + diretas', badge: 'badge-gray', bText: 'Setup' });
  if (sessions.length && sessions[0].confidence < 6) actions.push({ text: 'Foco: filler words na próxima sessão', sub: 'Confiança baixa na última sessão', badge: 'badge-red', bText: 'Urgente' });
  if (!actions.length) actions.push({ text: 'Continue a sequência diária', sub: calcStreak() + ' dias de streak — não quebre', badge: 'badge-green', bText: 'Em dia' });

  actEl.innerHTML = actions.map(a => `
    <div class="list-item">
      <div class="list-item-body">
        <div class="list-item-title">${a.text}</div>
        <div class="list-item-sub">${a.sub}</div>
      </div>
      <div class="list-item-meta"><span class="badge ${a.badge}">${a.bText}</span></div>
    </div>`).join('');
}

async function callAI(prompt) {
  const r = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ model: 'claude-sonnet-4-6', max_tokens: 1000, messages: [{ role: 'user', content: prompt }] })
  });
  const d = await r.json();
  return d.content?.[0]?.text || 'Erro ao processar.';
}

async function analyzeSession() {
  const box = document.getElementById('e-ai-box');
  const body = document.getElementById('e-ai-body');
  const spin = document.getElementById('e-spin');
  box.style.display = 'block';
  spin.innerHTML = '<span class="spinner"></span> ';
  body.textContent = 'Analisando...';

  const prompt = `Você é um coach de inglês para entrevistas B2B internacionais. Analise esta sessão de prática de um profissional de marketing brasileiro (B2, buscando vagas remotas nos EUA).

Foco: ${document.getElementById('e-focus').value}
Confiança: ${document.getElementById('e-conf').value}/10
Filler words: ${document.getElementById('e-fill').value}
O que funcionou: ${document.getElementById('e-win').value}
Gap identificado: ${document.getElementById('e-gap').value}
${document.getElementById('e-transcript').value ? 'Transcrição:\n' + document.getElementById('e-transcript').value.slice(0,1500) : ''}

Responda em português, em 3 partes diretas:
1. PADRÃO IDENTIFICADO (1 frase cirúrgica)
2. EXERCÍCIO PARA AMANHÃ (ação concreta de 5–10 min)
3. FRASE-ÂNCORA (uma frase em inglês para praticar hoje, relacionada ao gap)`;

  try {
    const result = await callAI(prompt);
    spin.innerHTML = '';
    body.textContent = result;
  } catch(e) {
    spin.innerHTML = '';
    body.textContent = 'Erro na análise. Salve a sessão e traga a transcrição para o chat do Claude.';
  }
}

async function analyzeInterview() {
  const box = document.getElementById('i-ai-box');
  const body = document.getElementById('i-ai-body');
  const spin = document.getElementById('i-spin');
  box.style.display = 'block';
  spin.innerHTML = '<span class="spinner"></span> ';
  body.textContent = 'Diagnosticando...';

  const prompt = `Você é um coach de carreira para profissionais de marketing LATAM buscando vagas remotas nos EUA. Seja direto e cirúrgico.

Empresa: ${document.getElementById('i-co').value} | Vaga: ${document.getElementById('i-role').value}
Resultado: ${document.getElementById('i-outcome').value}
STAR: ${document.getElementById('i-star').value}/5 | Fluência: ${document.getElementById('i-flu').value}/5 | Presença: ${document.getElementById('i-pres').value}/5 | Técnico: ${document.getElementById('i-tech').value}/5 | Fit: ${document.getElementById('i-fit').value}/5
Funcionou: ${document.getElementById('i-win').value}
Gap: ${document.getElementById('i-gap').value}
Feedback empresa: ${document.getElementById('i-fb').value}
${document.getElementById('i-transcript').value ? 'Transcrição:\n' + document.getElementById('i-transcript').value.slice(0,1200) : ''}

Responda em português em 3 partes:
1. DIAGNÓSTICO REAL (por que não avançou — honesto, sem filtro)
2. MUDANÇA PRIORITÁRIA (uma coisa concreta para a próxima entrevista)
3. SCRIPT (reescreva em inglês a parte mais fraca, do jeito que deveria ser dita)`;

  try {
    const result = await callAI(prompt);
    spin.innerHTML = '';
    body.textContent = result;
  } catch(e) {
    spin.innerHTML = '';
    body.textContent = 'Erro na análise. Salve a entrevista e traga os dados para o chat.';
  }
}

function exportData() {
  const data = { sessions, interviews, jobs, exported: new Date().toISOString() };
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'growth-os-backup-' + today() + '.json';
  a.click();
}

